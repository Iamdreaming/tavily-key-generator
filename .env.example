# 邮箱服务
# 可选值: cloudflare / duckmail / cloudflare_temp_email
EMAIL_PROVIDER=cloudflare_temp_email

# Cloudflare 自定义邮箱 API (旧方案，保留兼容)
EMAIL_API_URL=https://your-mail-api.example.com
EMAIL_API_TOKEN=replace-with-your-token
EMAIL_DOMAIN=example.com
EMAIL_DOMAINS=example.com,example.org

# DuckMail API
# 公共域名可不填 DUCKMAIL_API_KEY；如果你有 DuckMail 私有域名 API Key，
# 直接填进来即可。
DUCKMAIL_API_URL=https://api.duckmail.sbs
DUCKMAIL_API_KEY=
DUCKMAIL_DOMAIN=
DUCKMAIL_DOMAINS=

# Cloudflare Temp Email (推荐)
# 部署 cloudflare_temp_email 后，填写你的 Worker 地址和 Admin 密码
CF_TEMP_EMAIL_API_URL=https://your-worker.workers.dev
CF_TEMP_EMAIL_ADMIN_PASSWORD=replace-with-your-admin-password
CF_TEMP_EMAIL_DOMAIN=example.com
CF_TEMP_EMAIL_DOMAINS=example.com,example.org

# 可选：注册完成后上传到你自己的 key 池
SERVER_URL=https://your-server.example.com
SERVER_ADMIN_PASSWORD=replace-with-your-admin-password
DEFAULT_UPLOAD=true

# 运行参数
DEFAULT_COUNT=1
DEFAULT_CONCURRENCY=2
DEFAULT_DELAY=10
# 关闭 headless，Turnstile 有头模式通过率更高
REGISTER_HEADLESS=false
FIRECRAWL_REGISTER_HEADLESS=true
EMAIL_CODE_TIMEOUT=90
API_KEY_TIMEOUT=20
EMAIL_POLL_INTERVAL=3

# Solver
SOLVER_PORT=5073
# 实际启动时会自动取 max(SOLVER_THREADS, 本轮并发数)
SOLVER_THREADS=1
